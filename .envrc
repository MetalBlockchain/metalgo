# Repo-local commands like ginkgo and tmpnetctl
PATH_add bin

# Built binaries like metalgo and xsvm
PATH_add build

# Configure the explicit built path of avalanchego for tmpnet usage
export METALGO_PATH=$PWD/build/metalgo

# Configure the local plugin directory for both metalgo and tmpnet usage
mkdir -p $PWD/build/plugins                                       # metalgo will FATAL if the directory does not exist
export METALGO_PLUGIN_DIR="${METALGO_PLUGIN_DIR:-$PWD/build/plugins}" # Use an existing value if set
